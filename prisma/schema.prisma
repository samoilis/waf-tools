generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ────────────────────────────────────────

enum UserRole {
  ADMIN
  VIEWER
}

enum AuthProvider {
  LOCAL
  LDAP
  RADIUS
  TACACS
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  password     String?      // bcrypt hash — null for external auth users
  displayName  String?
  role         UserRole     @default(VIEWER)
  authProvider AuthProvider @default(LOCAL)
  isSystem     Boolean      @default(false) // true = cannot be deleted (default admin)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  configSnapshots ConfigSnapshot[]
  auditLogs       AuditLog[]
}

// ─── Application Settings ───────────────────────────────

model Setting {
  id    String @id @default(cuid())
  key   String @unique // e.g. "ldap.host", "radius.host", "tacacs.host"
  value String         // encrypted where needed
}

// ─── WAF Vendor ─────────────────────────────────────────

enum WafVendor {
  IMPERVA
  IMPERVA_CLOUD
  FORTIWEB
  CLOUDFLARE
  AWS_WAF
  AKAMAI
}

// ─── WAF Server (vendor-agnostic) ────────────────────────

model WafServer {
  id          String    @id @default(cuid())
  name        String
  host        String
  port        Int       @default(8083)
  vendorType  WafVendor
  credentials Json      // vendor-specific auth: Imperva { username, authorization }, FortiWeb { apiKey }
  entityTypes Json      @default("[]") // [{ key, label }] populated per adapter
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  backupTasks     BackupTask[]     @relation("WafServerTasks")
  configSnapshots ConfigSnapshot[] @relation("WafServerSnapshots")
}

// ─── Backup Task Definition ─────────────────────────────

enum BackupTaskStatus {
  ACTIVE
  PAUSED
}

model BackupTask {
  id             String           @id @default(cuid())
  name           String
  serverId       String
  scope          Json
  cronExpression String           @default("0 2 * * *")
  status         BackupTaskStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  server     WafServer      @relation("WafServerTasks", fields: [serverId], references: [id], onDelete: Cascade)
  executions ExecutionLog[]

  @@index([serverId])
}

// ─── Execution Log ──────────────────────────────────────

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model ExecutionLog {
  id           String          @id @default(cuid())
  taskId       String
  status       ExecutionStatus @default(RUNNING)
  errorMessage String?
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?

  task      BackupTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  snapshots BackupSnapshot[]

  @@index([taskId])
  @@index([startedAt])
}

// ─── Backup Snapshot (DB-only storage) ──────────────────

model BackupSnapshot {
  id          String   @id @default(cuid())
  executionId String
  entityType  String   // e.g. "site", "server_group", "ip_dictionary", "web_profile"
  entityId    String   // Imperva entity ID
  entityName  String
  data        Json     // full exported config as JSONB
  createdAt   DateTime @default(now())

  execution ExecutionLog @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([entityType, entityId])
}

// ─── Config Snapshot (user-created modified copies) ─────

model ConfigSnapshot {
  id          String   @id @default(cuid())
  name        String
  description String?
  serverId    String
  basedOnExec String?  // execution this snapshot was derived from
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server    WafServer          @relation("WafServerSnapshots", fields: [serverId], references: [id], onDelete: Cascade)
  createdBy User               @relation(fields: [createdById], references: [id])
  items     ConfigSnapshotItem[]

  @@index([serverId])
  @@index([createdById])
}

model ConfigSnapshotItem {
  id         String @id @default(cuid())
  snapshotId String
  entityType String  // e.g. "site", "ip_group", "web_profile"
  entityId   String
  entityName String
  data       Json    // modified config data as JSONB

  snapshot ConfigSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([entityType, entityId])
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  username   String   // denormalized so logs survive user deletion
  action     String   // e.g. "LOGIN", "CREATE_USER", "DELETE_SERVER", "UPDATE_SETTING"
  target     String?  // e.g. "User:admin", "WafServer:abc123"
  details    Json?    // optional extra context
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
