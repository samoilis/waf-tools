{
	"servers": {
		"prisma": {
			"command": "pnpm",
			"args": [
				"prisma",
				"mcp"
			],
			"type": "stdio"
		},
		"mantine-docs": {
			"type": "http",
			"url": "https://mantinedev.gitmcp.io/mantine"
		},
		"neon": {
     	"type": "http",
      "url": "https://mcp.neon.tech/mcp",
			"headers": {
				"Authorization": "Bearer ${input:neon-api-key}"
			}
  	},
		"chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--headless", "true"]
    }
	},
	"inputs": [
		{
			"id": "neon-api-key",
			"type": "promptString",
			"description": "Neon API Key (from https://console.neon.tech/app/settings/api-keys)",
			"password": true
		}
	]
}