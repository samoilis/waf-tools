# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://wt_user:YOUR_PASSWORD@localhost:5432/waftools"

# ─── Authentication (Required) ────────────────────────
# Generate with: openssl rand -base64 48
AUTH_SECRET="replace-with-a-random-secret"

# Public URL of your instance (used by NextAuth for redirects)
AUTH_URL="https://your-domain.com"

# Trust the Host header (must be true behind a reverse proxy)
AUTH_TRUST_HOST=true

# ─── License (Optional) ───────────────────────────────
# Can also be set via UI → Settings → Registration
# LICENSE_KEY="your-license-key-here"

# ─── Worker ───────────────────────────────────────────
# Set to 0 if your WAF servers use self-signed certificates
NODE_TLS_REJECT_UNAUTHORIZED=0
